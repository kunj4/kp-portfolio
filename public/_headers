# Cloudflare Pages security headers for the static export (`output: export`).
# next.config.js `headers()` does NOT apply to statically exported sites, so
# these are the production source of truth.
#
# FRAME PROTECTION IS NOT SET HERE. Cloudflare _headers APPENDS every matching
# rule (it can't override `/*` for one path), so a `/*` X-Frame-Options would
# also hit the resume PDF and block its same-origin iframe. Instead, frame
# protection is applied via a Cloudflare Transform Rule:
#   Set response header  X-Frame-Options: DENY
#   When  (http.request.uri.path ne "/Kunj_Patel_Senior_Security_Engineer.pdf")
# That gives every page DENY while leaving the resume PDF embeddable.
# (Note: next.config.js still sets frame headers for local `next dev`/`start`,
#  where Next.js *does* honor per-path overrides.)

/Kunj_Patel_Senior_Security_Engineer.pdf
  Cache-Control: public, max-age=300, must-revalidate

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' giscus.app analytics.umami.is us.umami.is cloud.umami.is static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https:; media-src 'self' https://*.s3.amazonaws.com; connect-src 'self' analytics.umami.is us.umami.is cloud.umami.is cloudflareinsights.com; font-src 'self'; frame-src 'self' giscus.app; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-DNS-Prefetch-Control: on
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()
